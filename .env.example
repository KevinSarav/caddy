# Copy this file to .env and set your deSEC token.
# Needed by Caddy DNS-01 ACME challenge via the deSEC provider plugin.
DESEC_TOKEN=replace_with_desec_token

# Optional contact email used in your private Caddyfile.
# CADDY_EMAIL=you@example.com

# Domain alias used on the shared proxy network for S3 routing.
S3_DOMAIN_ALIAS=s3.example.com

# Optional version pins (defaults are baked into compose.yaml / Dockerfile):
# CADDY_VERSION=2.11
# DESEC_MODULE_VERSION=v1.1.0
# CADDY_IMAGE=local/caddy-desec:2.11
